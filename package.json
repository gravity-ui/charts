{
  "name": "@gravity-ui/charts",
  "version": "1.49.1",
  "description": "A flexible JavaScript library for data visualization and chart rendering using React",
  "license": "MIT",
  "main": "dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/esm/index.d.js",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "sideEffects": [
    "*.css",
    "*.scss"
  ],
  "files": [
    "dist",
    "!**/__tests__/**",
    "!**/__stories__/**",
    "!**/__mocks__/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gravity-ui/charts.git"
  },
  "bugs": {
    "url": "https://github.com/gravity-ui/charts/issues"
  },
  "homepage": "https://github.com/gravity-ui/charts#readme",
  "scripts": {
    "prepare": "husky",
    "lint": "run-p lint:*",
    "lint:js": "eslint --report-unused-disable-directives .",
    "lint:js:fix": "eslint --fix --report-unused-disable-directives .",
    "lint:styles": "stylelint --report-needless-disables 'src/**/*.scss'",
    "lint:other": "npm run prettier -- --check",
    "prettier": "prettier '**/*.{md,yaml,yml,json}'",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "clean": "gulp clean",
    "build": "gulp",
    "start": "storybook dev -p 7007",
    "build-storybook": "storybook build -c .storybook -o storybook-static",
    "prepublishOnly": "npm run build",
    "docs:deps": "cd ./docs && npm ci",
    "docs:dev": "cd ./docs && npm run docs:dev",
    "docs:build-examples": "vite build --config docs/examples/vite.config.ts",
    "docs:build": "npm run docs:build-examples && cd ./docs && npm run docs:build",
    "playwright:install": "playwright install chromium webkit --with-deps",
    "playwright": "playwright test --config=playwright/playwright.config.ts",
    "playwright:visual": "playwright test --project=chromium --project=webkit --config=playwright/playwright.config.ts",
    "playwright:perf": "playwright test --project=chromium-perf --workers=1 --no-deps --config=playwright/playwright.config.ts",
    "playwright:update": "npm run playwright -- -u",
    "playwright:clear-cache": "rm -rf ./playwright/.cache",
    "playwright:docker": "./scripts/playwright-docker.sh 'npm run playwright'",
    "playwright:docker:update": "./scripts/playwright-docker.sh 'npm run playwright:update'",
    "playwright:docker:clear-cache": "./scripts/playwright-docker.sh clear-cache"
  },
  "dependencies": {
    "@bem-react/classname": "^1.6.0",
    "@gravity-ui/date-utils": "^2.5.4",
    "@gravity-ui/i18n": "^1.6.0",
    "@gravity-ui/icons": "^2.15.0",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-brush": "^3.0.0",
    "d3-color": "^3.1.0",
    "d3-delaunay": "^6.0.4",
    "d3-dispatch": "^3.0.1",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-path": "^3.1.0",
    "d3-random": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "html-react-parser": "^5.2.17",
    "lodash": "^4.17.21",
    "tslib": "^2.6.2"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.5",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@gravity-ui/eslint-config": "^4.2.1",
    "@gravity-ui/prettier-config": "^1.1.0",
    "@gravity-ui/stylelint-config": "^4.0.1",
    "@gravity-ui/tsconfig": "^1.0.0",
    "@gravity-ui/uikit": "^7.18.0",
    "@playwright/experimental-ct-react": "^1.56.1",
    "@playwright/test": "^1.56.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/react": "^10.2.16",
    "@storybook/react-vite": "^10.2.16",
    "@testing-library/dom": "^10.1.0",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/d3": "^7.4.3",
    "@types/d3-selection": "^3.0.11",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-storybook": "^10.2.16",
    "eslint-plugin-testing-library": "^6.2.2",
    "globals": "^17.4.0",
    "gulp": "^5.0.0",
    "gulp-cli": "^3.0.0",
    "gulp-dart-sass": "^1.1.0",
    "gulp-replace": "^1.1.4",
    "gulp-typescript": "^5.0.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-transform-css": "^6.0.1",
    "monaco-editor": "^0.55.1",
    "nano-staged": "^0.8.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^5.0.7",
    "sass": "^1.77.1",
    "storybook": "^10.2.16",
    "stylelint": "^15.11.0",
    "stylelint-use-logical": "^2.1.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "overrides": {
    "dompurify": "^3.4.0"
  },
  "peerDependencies": {
    "@gravity-ui/uikit": "^7.0.0",
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "nano-staged": {
    "*.{scss}": [
      "stylelint --fix --quiet --report-needless-disables"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --quiet --report-unused-disable-directives"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
